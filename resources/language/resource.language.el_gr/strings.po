# Kodi language file
# Addon: service.trickplay
msgid ""
msgstr ""
"Language: el\n"
"Content-Type: text/plain; charset=UTF-8\n"

msgctxt "#32000"
msgid "General"
msgstr "Γενικά"

msgctxt "#32001"
msgid "Trickplay"
msgstr "Trickplay"

msgctxt "#32002"
msgid "Preferred tile width (px)"
msgstr "Προτιμώμενο πλάτος πλακιδίου (px)"

msgctxt "#32003"
msgid "Resolution subfolder to prefer inside the .trickplay directory (e.g. 320 for '320 - 10x10 - 10000'). Falls back to the first resolution found."
msgstr "Υποφάκελος ανάλυσης προτίμησης μέσα στον κατάλογο .trickplay (π.χ. 320 για '320 - 10x10 - 10000'). Επιστρέφει στην πρώτη ανάλυση που βρέθηκε."

msgctxt "#32004"
msgid "Thumbnail interval (ms)"
msgstr "Διάστημα μικρογραφιών (ms)"

msgctxt "#32005"
msgid "Preferred interval when selecting a sidecar folder and fallback when the folder name has no interval suffix (legacy '320 - 10x10' uses 10000 ms)."
msgstr "Προτιμώμενο διάστημα κατά την επιλογή φακέλου sidecar και εναλλακτική όταν το όνομα φακέλου δεν έχει επίθημα διαστήματος (legacy '320 - 10x10' χρησιμοποιεί 10000 ms)."

msgctxt "#32006"
msgid "Seek poll interval (ms)"
msgstr "Διάστημα ενημέρωσης αναζήτησης (ms)"

msgctxt "#32007"
msgid "How often to refresh the preview while the seek bar is active. Lower values feel smoother but use more CPU."
msgstr "Συχνότητα ανανέωσης της προεπισκόπησης ενώ η γραμμή αναζήτησης είναι ενεργή. Χαμηλότερες τιμές είναι πιο ομαλές αλλά χρησιμοποιούν περισσότερη CPU."

msgctxt "#32008"
msgid "Enable debug logging"
msgstr "Ενεργοποίηση καταγραφής αποσφαλμάτωσης"

msgctxt "#32009"
msgid "Write detailed trickplay resolution messages to the Kodi log."
msgstr "Γράψτε λεπτομερή μηνύματα ανάλυσης trickplay στο αρχείο καταγραφής Kodi."

msgctxt "#32010"
msgid "Automatic tile calculation (legacy)"
msgstr "Αυτόματος υπολογισμός πλακιδίων (legacy)"

msgctxt "#32011"
msgid "Deprecated; use Preview tile grid layout instead."
msgstr "Παρωχημένο· χρησιμοποιήστε αντί αυτού Διάταξη πλέγματος πλακιδίων προεπισκόπησης."

msgctxt "#32012"
msgid "Number of tiles"
msgstr "Αριθμός πλακιδίων"

msgctxt "#32013"
msgid "Manual grid layout per sprite JPG, e.g. 10x10 or 20x20. Each cell size is still calculated from the JPG width and height divided by these counts."
msgstr "Χειροκίνητη διάταξη πλέγματος ανά JPG sprite, π.χ. 10x10 ή 20x20. Το μέγεθος κάθε κελιού υπολογίζεται ακόμα από το πλάτος και ύψος του JPG διαιρεμένο με αυτούς τους αριθμούς."

msgctxt "#32014"
msgid "Skin profile"
msgstr "Προφίλ θέματος"

msgctxt "#32015"
msgid "Seek bar geometry and focus IDs for preview placement. Auto detects your active Kodi skin; override if detection fails."
msgstr "Γεωμετρία γραμμής αναζήτησης και ID εστίασης για τοποθέτηση προεπισκόπησης. Ανιχνεύει αυτόματα το ενεργό θέμα Kodi· παράκαμψη αν η ανίχνευση αποτύχει."

msgctxt "#32016"
msgid "Auto (detect active skin)"
msgstr "Αυτόματο (ανίχνευση ενεργού θέματος)"

msgctxt "#32017"
msgid "Estuary Mod v2"
msgstr "Estuary Mod v2"

msgctxt "#32018"
msgid "Arctic Fuse 3"
msgstr "Arctic Fuse 3"

msgctxt "#32019"
msgid "Preview hold time (seconds)"
msgstr "Χρόνος διατήρησης προεπισκόπησης (δευτερόλεπτα)"

msgctxt "#32020"
msgid "How long to keep the preview visible after seeking stops. 0 = until the OSD closes; the thumbnail follows playback while playing."
msgstr "Πόσο καιρό θα διατηρείται ορατή η προεπισκόπηση αφού σταματήσει η αναζήτηση. 0 = μέχρι να κλείσει το OSD· η μικρογραφία ακολουθεί την αναπαραγωγή κατά την αναπαραγωγή."

msgctxt "#32021"
msgid "Show timestamp"
msgstr "Εμφάνιση χρονικής σήμανσης"

msgctxt "#32022"
msgid "Show the seek position timestamp below the preview thumbnail."
msgstr "Εμφάνιση της χρονικής σήμανσης θέσης αναζήτησης κάτω από τη μικρογραφία προεπισκόπησης."

msgctxt "#32023"
msgid "Enable prefetch"
msgstr "Ενεργοποίηση προφόρτωσης"

msgctxt "#32024"
msgid "Pre-crop neighbouring trickplay cells in the background so scrubbing feels faster."
msgstr "Προκοπή γειτονικών κελιών trickplay στο παρασκήνιο ώστε το scrubbing να φαίνεται πιο γρήγορο."

msgctxt "#32200"
msgid "Prefetch during playback"
msgstr "Προφόρτωση κατά την αναπαραγωγή"

msgctxt "#32201"
msgid "While a video is playing, keep the prefetch radius (thumb indices) warm on both sides of the current playhead — not only when the seek bar opens."
msgstr "Ενώ αναπαράγεται ένα βίντεο, διατηρήστε την ακτίνα προφόρτωσης (δείκτες μικρογραφιών) ζεστή και στις δύο πλευρές της τρέχουσας κεφαλής αναπαραγωγής — όχι μόνο όταν ανοίγει η γραμμή αναζήτησης."

msgctxt "#32202"
msgid "Arctic Fuse 2"
msgstr "Arctic Fuse 2"

msgctxt "#32203"
msgid "Arctic Horizon 2"
msgstr "Arctic Horizon 2"

msgctxt "#32204"
msgid "Arctic Zephyr 2 Resurrection"
msgstr "Arctic Zephyr 2 Resurrection"

msgctxt "#32205"
msgid "Bello"
msgstr "Bello"

msgctxt "#32206"
msgid "Arctic Horizon 2.1 Arizen"
msgstr "Arctic Horizon 2.1 Arizen"

msgctxt "#32207"
msgid "Bingie"
msgstr "Bingie"

msgctxt "#32208"
msgid "Arctic Zephyr Rounded"
msgstr "Arctic Zephyr Rounded"

msgctxt "#32209"
msgid "DialogSeekBar.xml has no seek-bar content (no controls or includes); skipped"
msgstr "Το DialogSeekBar.xml δεν έχει περιεχόμενο γραμμής αναζήτησης (χωρίς στοιχεία ελέγχου ή includes)· παραλείφθηκε"

msgctxt "#32210"
msgid "Skin snippet target XML not found"
msgstr "Το XML στόχος του αποσπάσματος θέματος δεν βρέθηκε"

msgctxt "#32025"
msgid "Prefetch on playback start"
msgstr "Προφόρτωση κατά την έναρξη αναπαραγωγής"

msgctxt "#32026"
msgid "Warm the cache around the current playhead when a video loads."
msgstr "Προθερμάνετε την προσωρινή μνήμη γύρω από την τρέχουσα κεφαλή αναπαραγωγής όταν φορτώνει ένα βίντεο."

msgctxt "#32027"
msgid "Prefetch whole sprite tile"
msgstr "Προφόρτωση ολόκληρου πλακιδίου sprite"

msgctxt "#32028"
msgid "Also queue uncached cells from the current sprite JPG (up to 20 per preview update)."
msgstr "Επίσης θέστε σε ουρά κελιά που δεν είναι στην προσωρινή μνήμη από το τρέχον JPG sprite (έως 20 ανά ενημέρωση προεπισκόπησης)."

msgctxt "#32029"
msgid "Prefetch idle sprite tile"
msgstr "Προφόρτωση αδρανούς πλακιδίου sprite"

msgctxt "#32030"
msgid "While the seek OSD is open and idle, pre-crop remaining cells in the current sprite tile."
msgstr "Ενώ το OSD αναζήτησης είναι ανοιχτό και αδρανές, προκόψτε τα υπόλοιπα κελιά στο τρέχον πλακίδιο sprite."

msgctxt "#32031"
msgid "Prefetch radius (indices)"
msgstr "Ακτίνα προφόρτωσης (δείκτες)"

msgctxt "#32032"
msgid "How many trickplay thumb indices to pre-crop ahead and behind the playhead (symmetric). With a 10 s interval, 5 means about ±50 s. Higher uses more CPU and disk."
msgstr "Πόσοι δείκτες μικρογραφιών trickplay να προκοπούν μπροστά και πίσω από την κεφαλή αναπαραγωγής (συμμετρικά). Με διάστημα 10 s, το 5 σημαίνει περίπου ±50 s. Υψηλότερες τιμές χρησιμοποιούν περισσότερη CPU και δίσκο."

msgctxt "#32033"
msgid "Prefetch queue size"
msgstr "Μέγεθος ουράς προφόρτωσης"

msgctxt "#32034"
msgid "Maximum pending background crops. Neighbour previews can bump lower-priority jobs when full."
msgstr "Μέγιστες εκκρεμείς περικοπές παρασκηνίου. Οι γειτονικές προεπισκοπήσεις μπορούν να αντικαταστήσουν εργασίες χαμηλότερης προτεραιότητας όταν είναι γεμάτο."

msgctxt "#32035"
msgid "Crop cache limit (MB)"
msgstr "Όριο προσωρινής μνήμης περικοπών (MB)"

msgctxt "#32036"
msgid "Maximum disk space for cropped preview JPEGs. Oldest files are removed first. 0 = unlimited."
msgstr "Μέγιστος χώρος δίσκου για περικομμένα JPEG προεπισκόπησης. Τα παλαιότερα αρχεία αφαιρούνται πρώτα. 0 = απεριόριστο."

msgctxt "#32037"
msgid "Prefetch"
msgstr "Προφόρτωση"

msgctxt "#32038"
msgid "Preview opacity (%)"
msgstr "Αδιαφάνεια προεπισκόπησης (%)"

msgctxt "#32039"
msgid "Overall preview transparency (0 = invisible, 100 = fully opaque). Default 100."
msgstr "Συνολική διαφάνεια προεπισκόπησης (0 = αόρατο, 100 = πλήρως αδιαφανές). Προεπιλογή 100."

msgctxt "#32040"
msgid "Trickplay generator"
msgstr "Γεννήτρια Trickplay"

msgctxt "#32041"
msgid "Custom…"
msgstr "Προσαρμοσμένο…"

msgctxt "#32042"
msgid "Preview tile grid layout"
msgstr "Διάταξη πλέγματος πλακιδίων προεπισκόπησης"

msgctxt "#32043"
msgid "How to divide each sprite JPG when cropping preview thumbnails. Use From folder name for Jellyfin or generator sidecars; pick 20×20 (etc.) if your tiles use a different grid than the folder name."
msgstr "Πώς να διαιρέσετε κάθε JPG sprite κατά την περικοπή μικρογραφιών προεπισκόπησης. Χρησιμοποιήστε Από όνομα φακέλου για Jellyfin ή sidecar γεννήτριας· επιλέξτε 20×20 (κ.λπ.) αν τα πλακίδιά σας χρησιμοποιούν διαφορετικό πλέγμα από το όνομα φακέλου."

msgctxt "#32044"
msgid "10×10"
msgstr "10×10"

msgctxt "#32045"
msgid "20×20"
msgstr "20×20"

msgctxt "#32046"
msgid "5×5"
msgstr "5×5"

msgctxt "#32047"
msgid "15×15"
msgstr "15×15"

msgctxt "#32050"
msgid "Enable trickplay generator"
msgstr "Ενεργοποίηση γεννήτριας trickplay"

msgctxt "#32051"
msgid "Generate Jellyfin-compatible .trickplay sprite sidecars with ffmpeg. When disabled, all generator options are hidden."
msgstr "Δημιουργία συμβατών με Jellyfin sidecar sprite .trickplay με ffmpeg. Όταν απενεργοποιηθεί, όλες οι επιλογές γεννήτριας είναι κρυφές."

msgctxt "#32052"
msgid "Generate while idle"
msgstr "Δημιουργία κατά την αδράνεια"

msgctxt "#32053"
msgid "When Kodi is not playing video, generate trickplay for one library file at a time from the library folder below."
msgstr "Όταν το Kodi δεν αναπαράγει βίντεο, δημιουργήστε trickplay για ένα αρχείο βιβλιοθήκης τη φορά από τον παρακάτω φάκελο βιβλιοθήκης."

msgctxt "#32054"
msgid "Overwrite existing sidecars"
msgstr "Αντικατάσταση υπαρχόντων sidecar"

msgctxt "#32055"
msgid "Regenerate and replace trickplay when a matching .trickplay folder already exists for the preferred width and grid. Off by default."
msgstr "Αναδημιουργία και αντικατάσταση trickplay όταν υπάρχει ήδη φάκελος .trickplay που ταιριάζει για το προτιμώμενο πλάτος και πλέγμα. Απενεργοποιημένο από προεπιλογή."

msgctxt "#32056"
msgid "Library folder"
msgstr "Φάκελος βιβλιοθήκης"

msgctxt "#32057"
msgid "Root folder scanned for batch generation and idle generation. Uses the preferred tile width, interval, and generator grid above. Press OK when leaving Configure to save changes. Start batch generation from the add-on Information page (Run), not from inside Configure."
msgstr "Ριζικός φάκελος που σαρώνεται για δημιουργία δέσμης και δημιουργία αδράνειας. Χρησιμοποιεί το προτιμώμενο πλάτος πλακιδίου, διάστημα και πλέγμα γεννήτριας παραπάνω. Πατήστε OK κατά την έξοδο από τη Διαμόρφωση για αποθήκευση αλλαγών. Ξεκινήστε τη δημιουργία δέσμης από τη σελίδα Πληροφοριών πρόσθετου (Εκτέλεση), όχι από μέσα στη Διαμόρφωση."

msgctxt "#32058"
msgid "Grid used when writing new .trickplay sidecars (folder name e.g. '320 - 10x10 - 10000')."
msgstr "Πλέγμα που χρησιμοποιείται κατά τη σύνταξη νέων sidecar .trickplay (όνομα φακέλου π.χ. '320 - 10x10 - 10000')."

msgctxt "#32059"
msgid "Run library batch generation…"
msgstr "Εκτέλεση δημιουργίας δέσμης βιβλιοθήκης…"

msgctxt "#32060"
msgid "Scan the library folder and generate trickplay for all videos missing sidecars. Shows a progress dialog. Run from the add-on Information page after saving Configure with OK."
msgstr "Σάρωση του φακέλου βιβλιοθήκης και δημιουργία trickplay για όλα τα βίντεο που λείπουν sidecar. Εμφανίζει διάλογο προόδου. Εκτελέστε από τη σελίδα Πληροφοριών πρόσθετου αφού αποθηκεύσετε τη Διαμόρφωση με OK."

msgctxt "#32061"
msgid "Select library folder"
msgstr "Επιλογή φακέλου βιβλιοθήκης"

msgctxt "#32062"
msgid "Enable the trickplay generator in settings first."
msgstr "Ενεργοποιήστε πρώτα τη γεννήτρια trickplay στις ρυθμίσεις."

msgctxt "#32063"
msgid "Batch trickplay generation"
msgstr "Δημιουργία trickplay δέσμης"

msgctxt "#32064"
msgid "Generate trickplay for all videos under:\n%s"
msgstr "Δημιουργία trickplay για όλα τα βίντεο στο:\n%s"

msgctxt "#32065"
msgid "Use this folder"
msgstr "Χρήση αυτού του φακέλου"

msgctxt "#32066"
msgid "Choose another…"
msgstr "Επιλέξτε άλλο…"

msgctxt "#32067"
msgid "No videos need trickplay generation in that folder."
msgstr "Κανένα βίντεο δεν χρειάζεται δημιουργία trickplay σε αυτόν τον φάκελο."

msgctxt "#32068"
msgid "Generate trickplay for %d video(s)? This may take a long time."
msgstr "Δημιουργία trickplay για %d βίντεο; Αυτό μπορεί να πάρει πολύ χρόνο."

msgctxt "#32083"
msgid "Generate trickplay for %d of %d video(s)? %d already have matching sidecars and will be skipped."
msgstr "Δημιουργία trickplay για %d από %d βίντεο; %d έχουν ήδη αντίστοιχα sidecar και θα παραλειφθούν."

msgctxt "#32069"
msgid "Generating trickplay…"
msgstr "Δημιουργία trickplay…"

msgctxt "#32070"
msgid "File %d of %d"
msgstr "Αρχείο %d από %d"

msgctxt "#32071"
msgid "Done. Success: %d  Failed: %d"
msgstr "Ολοκληρώθηκε. Επιτυχία: %d  Αποτυχία: %d"

msgctxt "#32072"
msgid "From folder name"
msgstr "Από όνομα φακέλου"

msgctxt "#32073"
msgid "Generator tile grid layout"
msgstr "Διάταξη πλέγματος πλακιδίων γεννήτριας"

msgctxt "#32074"
msgid "Generator thumbnail interval (ms)"
msgstr "Διάστημα μικρογραφιών γεννήτριας (ms)"

msgctxt "#32075"
msgid "Time between generated preview frames. Written into the sidecar folder name (e.g. '320 - 10x10 - 1000'). Playback preview uses the interval from the folder when present; legacy folders without an interval use 10000 ms."
msgstr "Χρόνος μεταξύ των καρέ προεπισκόπησης που δημιουργούνται. Γράφεται στο όνομα φακέλου sidecar (π.χ. '320 - 10x10 - 1000'). Η προεπισκόπηση αναπαραγωγής χρησιμοποιεί το διάστημα από τον φάκελο όταν υπάρχει· οι φάκελοι legacy χωρίς διάστημα χρησιμοποιούν 10000 ms."

msgctxt "#32076"
msgid "Frame extraction mode"
msgstr "Λειτουργία εξαγωγής καρέ"

msgctxt "#32077"
msgid "Accurate: one ffmpeg call per thumbnail, seek after input (slow, frame-accurate). Fast: seek before input per thumbnail for wide intervals, or one fps decode pass per tile for intervals of 5s or less. Fast (batch seeks): several seek-before-input captures per ffmpeg process (small chunks) with per-frame Fast fallback; optional PyAV on local SDR. Biggest gains on local SDR files."
msgstr "Ακριβής: μία κλήση ffmpeg ανά μικρογραφία, αναζήτηση μετά την είσοδο (αργή, ακρίβεια καρέ). Γρήγορη: αναζήτηση πριν την είσοδο ανά μικρογραφία για ευρεία διαστήματα, ή μία πάσα αποκωδικοποίησης fps ανά πλακίδιο για διαστήματα 5s ή λιγότερο. Πειραματική: ένα ανοιχτό αρχείο με αναζήτηση μεταξύ λήψεων (PyAV όταν διατίθεται, διαφορετικά μία διαδικασία ffmpeg με πολλές αναζητήσεις ανά πλακίδιο)."

msgctxt "#32080"
msgid "Accurate (slow)"
msgstr "Ακριβής (αργή)"

msgctxt "#32081"
msgid "Fast"
msgstr "Γρήγορη"

msgctxt "#32082"
msgid "Fast (batch seeks)"
msgstr "Fast (batch seeks)"

msgctxt "#32078"
msgid "Stop batch on first failure"
msgstr "Διακοπή δέσμης στην πρώτη αποτυχία"

msgctxt "#32079"
msgid "When running Generate trickplay for library, stop the batch after the first file that fails instead of continuing with the remaining videos."
msgstr "Κατά την εκτέλεση Δημιουργία trickplay για βιβλιοθήκη, διακόψτε τη δέσμη μετά το πρώτο αρχείο που αποτυγχάνει αντί να συνεχίσετε με τα υπόλοιπα βίντεο."

msgctxt "#32084"
msgid "Generate on library update"
msgstr "Δημιουργία κατά την ενημέρωση βιβλιοθήκης"

msgctxt "#32085"
msgid "After a video library scan finishes, generate trickplay for videos added during that scan. Listens for VideoLibrary.OnAdd and OnUpdate (added) notifications."
msgstr "Αφού ολοκληρωθεί μια σάρωση βιβλιοθήκης βίντεο, δημιουργήστε trickplay για βίντεο που προστέθηκαν κατά τη διάρκεια αυτής της σάρωσης. Ακούει ειδοποιήσεις VideoLibrary.OnAdd και OnUpdate (προστέθηκε)."

msgctxt "#32086"
msgid "Library update: only when not playing"
msgstr "Ενημέρωση βιβλιοθήκης: μόνο όταν δεν αναπαράγεται"

msgctxt "#32087"
msgid "Wait until Kodi is not playing video before starting trickplay generation for newly added library items."
msgstr "Περιμένετε μέχρι το Kodi να μην αναπαράγει βίντεο πριν ξεκινήσετε τη δημιουργία trickplay για πρόσφατα προστεθέντα στοιχεία βιβλιοθήκης."

msgctxt "#32088"
msgid "That folder is not a valid library path. Choose a folder that contains your video files (for example an NFS share or /storage/remote-shares/…)."
msgstr "Αυτός ο φάκελος δεν είναι έγκυρη διαδρομή βιβλιοθήκης. Επιλέξτε έναν φάκελο που περιέχει τα αρχεία βίντεό σας (για παράδειγμα ένα κοινόχρηστο NFS ή /storage/remote-shares/…)."

msgctxt "#32089"
msgid "Interval selection"
msgstr "Επιλογή διαστήματος"

msgctxt "#32090"
msgid "When multiple sidecar folders exist for the same tile width (e.g. 320 - 10x10 - 5000 and 320 - 10x10 - 10000), choose which interval to use during playback. Preferred uses the Preview thumbnail interval setting; Shortest uses the smallest interval available."
msgstr "Όταν υπάρχουν πολλοί φάκελοι sidecar για το ίδιο πλάτος πλακιδίου (π.χ. 320 - 10x10 - 5000 και 320 - 10x10 - 10000), επιλέξτε ποιο διάστημα θα χρησιμοποιηθεί κατά την αναπαραγωγή. Το Προτιμώμενο χρησιμοποιεί τη ρύθμιση Διάστημα μικρογραφιών προεπισκόπησης· Το Συντομότερο χρησιμοποιεί το μικρότερο διαθέσιμο διάστημα."

msgctxt "#32091"
msgid "Preferred interval"
msgstr "Προτιμώμενο διάστημα"

msgctxt "#32092"
msgid "Shortest interval"
msgstr "Συντομότερο διάστημα"

msgctxt "#32093"
msgid "HDR tone mapping for previews"
msgstr "Αντιστοίχιση τόνων HDR για προεπισκοπήσεις"

msgctxt "#32094"
msgid "Tone-map HDR and Dolby Vision sources to SDR when generating trickplay JPEGs so colours match normal playback (similar to Jellyfin). Only applies to HDR/DV files; SDR generation is unchanged. Significantly slower on 4K HEVC — often several times longer per file — and requires ffmpeg tonemap support. Leave off if Jellyfin already generates sidecars or generation time matters."
msgstr "Αντιστοίχιση τόνων πηγών HDR και Dolby Vision σε SDR κατά τη δημιουργία JPEG trickplay ώστε τα χρώματα να ταιριάζουν με την κανονική αναπαραγωγή (όπως το Jellyfin). Ισχύει μόνο για αρχεία HDR/DV· η δημιουργία SDR παραμένει αμετάβλητη. Σημαντικά πιο αργή σε 4K HEVC — συχνά πολλές φορές μεγαλύτερη ανά αρχείο — και απαιτεί υποστήριξη tonemap ffmpeg. Αφήστε απενεργοποιημένο αν το Jellyfin δημιουργεί ήδη sidecar ή ο χρόνος δημιουργίας έχει σημασία."

msgctxt "#32095"
msgid "HDR dovi_tool fallback"
msgstr "Εναλλακτική HDR dovi_tool"

msgctxt "#32096"
msgid "When HDR tone mapping is on, run dovi_tool on the first seconds of HEVC if ffprobe finds no HDR signals. Slower; place dovi_tool in generator ffmpeg bin/ (same folder as HDR ffmpeg) or on PATH. Use for stubborn Dolby Vision remuxes. Skipped for VFS stream paths. With fallback on, Run can offer to download dovi_tool there."
msgstr "Όταν η αντιστοίχιση τόνων HDR είναι ενεργή, εκτελέστε dovi_tool στα πρώτα δευτερόλεπτα του HEVC αν το ffprobe δεν βρει σήματα HDR. Πιο αργή· τοποθετήστε το dovi_tool στο generator ffmpeg bin/ (ίδιος φάκελος με το HDR ffmpeg) ή στο PATH. Χρησιμοποιήστε για επίμονα remux Dolby Vision. Παραλείπεται για διαδρομές ροής VFS. Με την εναλλακτική ενεργή, το Εκτέλεση μπορεί να προσφέρει λήψη του dovi_tool εκεί."

msgctxt "#32097"
msgid "Generator ffmpeg path"
msgstr "Διαδρομή ffmpeg γεννήτριας"

msgctxt "#32098"
msgid "Optional folder or ffmpeg binary for trickplay generation (needs zscale or libplacebo for HDR tone mapping). Preview cropping uses Pillow separately. Leave empty to use /storage/.kodi/system/ffmpeg/ on Linux Kodi, or addon_data/service.trickplay/system/ffmpeg/ on Windows, when present; otherwise PATH. Use Install preview tools when the generator or HDR tone mapping is enabled, or batch Run when generating."
msgstr "Προαιρετικός φάκελος ή δυαδικό ffmpeg για δημιουργία trickplay (χρειάζεται zscale ή libplacebo για αντιστοίχιση τόνων HDR). Η περικοπή προεπισκόπησης χρησιμοποιεί Pillow ξεχωριστά. Αφήστε κενό για χρήση /storage/.kodi/system/ffmpeg/ σε Linux Kodi, ή addon_data/service.trickplay/system/ffmpeg/ σε Windows, όταν υπάρχει· διαφορετικά PATH. Χρησιμοποιήστε Εγκατάσταση εργαλείων προεπισκόπησης όταν η γεννήτρια ή η αντιστοίχιση τόνων HDR είναι ενεργοποιημένη, ή δέσμη Εκτέλεση κατά τη δημιουργία."

msgctxt "#32099"
msgid "HDR tone mapping needs a capable ffmpeg build. Download and install now?\n\nLinux: BtbN gpl-8.1 (zscale). Windows: Gyan full build (zscale + libplacebo for Dolby Vision via Vulkan).\n\nOn devices without Vulkan (e.g. CoreELEC), Profile 5 Dolby Vision uses dovi_tool instead of libplacebo.\n\nInstall location: %s"
msgstr "Η αντιστοίχιση τόνων HDR χρειάζεται μια ικανή έκδοση ffmpeg. Λήψη και εγκατάσταση τώρα;\n\nLinux: BtbN gpl-8.1 (zscale). Windows: Gyan full build (zscale + libplacebo για Dolby Vision μέσω Vulkan).\n\nΣε συσκευές χωρίς Vulkan (π.χ. CoreELEC), το Profile 5 Dolby Vision χρησιμοποιεί dovi_tool αντί για libplacebo.\n\nΘέση εγκατάστασης: %s"

msgctxt "#32100"
msgid "Continue without"
msgstr "Συνέχεια χωρίς"

msgctxt "#32101"
msgid "Installing HDR ffmpeg…"
msgstr "Εγκατάσταση HDR ffmpeg…"

msgctxt "#32102"
msgid "Automatic HDR ffmpeg install is not supported on this platform. Install a BtbN build manually (see README)."
msgstr "Η αυτόματη εγκατάσταση HDR ffmpeg δεν υποστηρίζεται σε αυτή την πλατφόρμα. Εγκαταστήστε χειροκίνητα μια έκδοση BtbN (δείτε README)."

msgctxt "#32103"
msgid "HDR ffmpeg install failed:\n%s\n\nYou can install manually or continue with the current ffmpeg (HDR previews may look washed out)."
msgstr "Η εγκατάσταση HDR ffmpeg απέτυχε:\n%s\n\nΜπορείτε να εγκαταστήσετε χειροκίνητα ή να συνεχίσετε με το τρέχον ffmpeg (οι προεπισκοπήσεις HDR μπορεί να φαίνονται ξεθωριασμένες)."

msgctxt "#32104"
msgid "HDR ffmpeg installed (%s)."
msgstr "Το HDR ffmpeg εγκαταστάθηκε (%s)."

msgctxt "#32105"
msgid "Download"
msgstr "Λήψη"

msgctxt "#32106"
msgid "dovi_tool is required on this device for Dolby Vision trickplay (no Vulkan / libvulkan) or when HDR dovi_tool fallback is enabled. Download and install dovi_tool beside generator ffmpeg now?\n\nInstall location: %s"
msgstr "Το dovi_tool απαιτείται σε αυτή τη συσκευή για trickplay Dolby Vision (χωρίς Vulkan / libvulkan) ή όταν η εναλλακτική HDR dovi_tool είναι ενεργοποιημένη. Λήψη και εγκατάσταση dovi_tool δίπλα στο ffmpeg γεννήτριας τώρα;\n\nΘέση εγκατάστασης: %s"

msgctxt "#32107"
msgid "Installing dovi_tool…"
msgstr "Εγκατάσταση dovi_tool…"

msgctxt "#32108"
msgid "Automatic dovi_tool install is not supported on this platform. Download from quietvoid/dovi_tool releases and place dovi_tool in generator ffmpeg bin/ (see README)."
msgstr "Η αυτόματη εγκατάσταση dovi_tool δεν υποστηρίζεται σε αυτή την πλατφόρμα. Κατεβάστε από quietvoid/dovi_tool releases και τοποθετήστε το dovi_tool στο generator ffmpeg bin/ (δείτε README)."

msgctxt "#32109"
msgid "dovi_tool install failed:\n%s\n\nYou can install manually in generator ffmpeg bin/ or continue without Dolby Vision fallback."
msgstr "Η εγκατάσταση dovi_tool απέτυχε:\n%s\n\nΜπορείτε να εγκαταστήσετε χειροκίνητα στο generator ffmpeg bin/ ή να συνεχίσετε χωρίς εναλλακτική Dolby Vision."

msgctxt "#32110"
msgid "dovi_tool installed (%s)."
msgstr "Το dovi_tool εγκαταστάθηκε (%s)."

msgctxt "#32111"
msgid "Run batch in background"
msgstr "Εκτέλεση δέσμης στο παρασκήνιο"

msgctxt "#32112"
msgid "When enabled, batch Run shows a start notification and runs without the progress dialog. Progress is written to the Kodi log. You cannot cancel from the UI (stop Kodi or wait for completion). A notification is shown when the batch finishes."
msgstr "Όταν ενεργοποιηθεί, η δέσμη Εκτέλεση εμφανίζει ειδοποίηση έναρξης και εκτελείται χωρίς το διάλογο προόδου. Η πρόοδος γράφεται στο αρχείο καταγραφής Kodi. Δεν μπορείτε να ακυρώσετε από το UI (σταματήστε το Kodi ή περιμένετε να ολοκληρωθεί). Εμφανίζεται ειδοποίηση όταν η δέσμη ολοκληρωθεί."

msgctxt "#32113"
msgid "Generating trickplay for %d file(s) — see log for progress"
msgstr "Δημιουργία trickplay για %d αρχείο/α — δείτε το αρχείο καταγραφής για την πρόοδο"

msgctxt "#32114"
msgid "Skip Dolby Vision Profile 5"
msgstr "Παράλειψη Dolby Vision Profile 5"

msgctxt "#32115"
msgid "When enabled, batch generation skips web-style Dolby Vision Profile 5 files (e.g. .DV. releases). Profile 5 needs a full dovi_tool convert before tonemapping — often hours plus ~1× video size temp space on devices like CoreELEC. Use a desktop with Vulkan or leave this off to process them."
msgstr "Όταν ενεργοποιηθεί, η δημιουργία δέσμης παραλείπει αρχεία Dolby Vision Profile 5 web-style (π.χ. κυκλοφορίες .DV.). Το Profile 5 χρειάζεται πλήρη μετατροπή dovi_tool πριν την αντιστοίχιση τόνων — συχνά ώρες συν ~1× μέγεθος βίντεο προσωρινό χώρο σε συσκευές όπως το CoreELEC. Χρησιμοποιήστε επιτραπέζιο με Vulkan ή αφήστε το απενεργοποιημένο για να τα επεξεργαστείτε."

msgctxt "#32116"
msgid "Generate trickplay for %d of %d video(s)? %d skipped (matching sidecars), %d skipped (Dolby Vision Profile 5)."
msgstr "Δημιουργία trickplay για %d από %d βίντεο; %d παραλείφθηκαν (αντίστοιχα sidecar), %d παραλείφθηκαν (Dolby Vision Profile 5)."

msgctxt "#32117"
msgid "Generate trickplay for %d of %d video(s)? %d skipped (Dolby Vision Profile 5)."
msgstr "Δημιουργία trickplay για %d από %d βίντεο; %d παραλείφθηκαν (Dolby Vision Profile 5)."

msgctxt "#32118"
msgid "Vulkan (vulkan-1.dll) is missing on this PC. Dolby Vision via libplacebo needs it. Download and install the Vulkan loader next to ffmpeg?\n\nInstall location: %s"
msgstr "Το Vulkan (vulkan-1.dll) λείπει από αυτόν τον υπολογιστή. Το Dolby Vision μέσω libplacebo το χρειάζεται. Λήψη και εγκατάσταση του φορτωτή Vulkan δίπλα στο ffmpeg;\n\nΘέση εγκατάστασης: %s"

msgctxt "#32119"
msgid "Vulkan loader installed (%s)."
msgstr "Ο φορτωτής Vulkan εγκαταστάθηκε (%s)."

msgctxt "#32120"
msgid "Windows hardware decode"
msgstr "Αποκωδικοποίηση υλικού Windows"

msgctxt "#32121"
msgid "On Windows only: D3D11VA (GPU) for 10-bit / HDR / Dolby Vision HEVC (~25–30% faster on 4K HDR/DV). Not for general use — 1080p H.264 SDR should use software decode (often faster, especially on deep seeks); long-interval SDR uses fps-batch per tile. Skipped for AVC and SDR 8-bit HEVC. After the first HW failure on a file, software decode is used for the rest of that job. Requires a full Windows ffmpeg build (e.g. Gyan full from Run). No effect on Linux or CoreELEC."
msgstr "Μόνο στα Windows: D3D11VA (GPU) για HEVC 10-bit / HDR / Dolby Vision (~25–30% ταχύτερο σε 4K HDR/DV). Όχι για γενική χρήση — 1080p H.264 SDR θα πρέπει να χρησιμοποιεί αποκωδικοποίηση λογισμικού (συχνά ταχύτερη, ειδικά σε βαθιές αναζητήσεις)· SDR μεγάλου διαστήματος χρησιμοποιεί fps-batch ανά πλακίδιο. Παραλείπεται για AVC και SDR HEVC 8-bit. Μετά την πρώτη αποτυχία HW σε ένα αρχείο, χρησιμοποιείται αποκωδικοποίηση λογισμικού για το υπόλοιπο αυτής της εργασίας. Απαιτεί πλήρη έκδοση ffmpeg Windows (π.χ. Gyan full από Εκτέλεση). Χωρίς επίδραση σε Linux ή CoreELEC."

msgctxt "#32122"
msgid "Preview tools"
msgstr "Εργαλεία προεπισκόπησης"

msgctxt "#32123"
msgid "Install preview tools"
msgstr "Εγκατάσταση εργαλείων προεπισκόπησης"

msgctxt "#32124"
msgid "Download Pillow for preview cropping (into add-on site-packages). When the generator is enabled or HDR tone mapping is on, also offers ffmpeg/ffprobe and optional HDR extras (zscale/libplacebo, Vulkan loader on Windows, dovi_tool). Batch Run installs generator ffmpeg separately when generating sidecars."
msgstr "Λήψη Pillow για περικοπή προεπισκόπησης (στα site-packages του πρόσθετου). Όταν η γεννήτρια είναι ενεργοποιημένη ή η αντιστοίχιση τόνων HDR είναι ενεργή, προσφέρει επίσης ffmpeg/ffprobe και προαιρετικά πρόσθετα HDR (zscale/libplacebo, φορτωτής Vulkan στα Windows, dovi_tool). Η δέσμη Εκτέλεση εγκαθιστά το ffmpeg γεννήτριας ξεχωριστά κατά τη δημιουργία sidecar."

msgctxt "#32125"
msgid "Trickplay generation needs ffmpeg and ffprobe. Download and install a pinned build now?\n\nLinux: BtbN gpl-8.1. Windows: Gyan full build (zscale + libplacebo for Dolby Vision via Vulkan).\n\nInstall location: %s"
msgstr "Η δημιουργία trickplay χρειάζεται ffmpeg και ffprobe. Λήψη και εγκατάσταση μιας καρφιτσωμένης έκδοσης τώρα;\n\nLinux: BtbN gpl-8.1. Windows: Gyan full build (zscale + libplacebo για Dolby Vision μέσω Vulkan).\n\nΘέση εγκατάστασης: %s"

msgctxt "#32126"
msgid "Installing ffmpeg…"
msgstr "Εγκατάσταση ffmpeg…"

msgctxt "#32127"
msgid "ffmpeg install failed:\n%s\n\nYou can install manually or set Generator ffmpeg path in add-on settings."
msgstr "Η εγκατάσταση ffmpeg απέτυχε:\n%s\n\nΜπορείτε να εγκαταστήσετε χειροκίνητα ή να ορίσετε τη Διαδρομή ffmpeg γεννήτριας στις ρυθμίσεις του πρόσθετου."

msgctxt "#32128"
msgid "ffmpeg installed (%s)."
msgstr "Το ffmpeg εγκαταστάθηκε (%s)."

msgctxt "#32129"
msgid "Preview tools are already installed."
msgstr "Τα εργαλεία προεπισκόπησης είναι ήδη εγκατεστημένα."

msgctxt "#32130"
msgid "This file has trickplay sidecars but preview thumbnails need Pillow to crop tiles from sprite sheets.\n\nDownload and install Pillow now? You can also use Install preview tools in add-on settings anytime."
msgstr "Αυτό το αρχείο έχει sidecar trickplay αλλά οι μικρογραφίες προεπισκόπησης χρειάζονται Pillow για να κόψουν πλακίδια από φύλλα sprite.\n\nΛήψη και εγκατάσταση Pillow τώρα; Μπορείτε επίσης να χρησιμοποιήσετε Εγκατάσταση εργαλείων προεπισκόπησης στις ρυθμίσεις του πρόσθετου ανά πάσα στιγμή."

msgctxt "#32131"
msgid "Install preview tools"
msgstr "Εγκατάσταση εργαλείων προεπισκόπησης"

msgctxt "#32132"
msgid "Calculating number of videos…"
msgstr "Υπολογισμός αριθμού βίντεο…"

msgctxt "#32133"
msgid "Please wait while the folder is scanned for videos missing trickplay preview files based on your current settings."
msgstr "Περιμένετε ενώ ο φάκελος σαρώνεται για βίντεο που λείπουν αρχεία προεπισκόπησης trickplay με βάση τις τρέχουσες ρυθμίσεις σας."

msgctxt "#32134"
msgid "Checking %d of %d videos…"
msgstr "Έλεγχος %d από %d βίντεο…"

msgctxt "#32135"
msgid "Scanning for video files… (%d found)"
msgstr "Σάρωση για αρχεία βίντεο… (%d βρέθηκαν)"

msgctxt "#32136"
msgid "Preview adjustment"
msgstr "Ρύθμιση προεπισκόπησης"

msgctxt "#32137"
msgid "Preview scale (%)"
msgstr "Κλίμακα προεπισκόπησης (%)"

msgctxt "#32138"
msgid "Scale the scrub preview thumbnail relative to the default size (100 = normal). Useful on 4K displays or with custom skin layouts."
msgstr "Κλιμάκωση της μικρογραφίας προεπισκόπησης scrubbing σε σχέση με το προεπιλεγμένο μέγεθος (100 = κανονικό). Χρήσιμο σε οθόνες 4K ή με προσαρμοσμένες διατάξεις θέματος."

msgctxt "#32139"
msgid "Preview horizontal offset (px)"
msgstr "Οριζόντια μετατόπιση προεπισκόπησης (px)"

msgctxt "#32140"
msgid "Estuary (stock)"
msgstr "Estuary (stock)"

msgctxt "#32141"
msgid "Aeon Nox SiLVO"
msgstr "Aeon Nox SiLVO"

msgctxt "#32142"
msgid "Arctic Zephyr"
msgstr "Arctic Zephyr"

msgctxt "#32143"
msgid "Arctic Horizon"
msgstr "Arctic Horizon"

msgctxt "#32144"
msgid "Shift the preview left (negative) or right (positive) in pixels @ 1080p."
msgstr "Μετακίνηση της προεπισκόπησης αριστερά (αρνητικό) ή δεξιά (θετικό) σε pixel @ 1080p."

msgctxt "#32145"
msgid "Preview vertical offset (px)"
msgstr "Κατακόρυφη μετατόπιση προεπισκόπησης (px)"

msgctxt "#32146"
msgid "Shift the preview up (negative) or down (positive) in pixels @ 1080p."
msgstr "Μετακίνηση της προεπισκόπησης επάνω (αρνητικό) ή κάτω (θετικό) σε pixel @ 1080p."

msgctxt "#32147"
msgid "Show preview when play controls focused"
msgstr "Εμφάνιση προεπισκόπησης όταν τα στοιχεία ελέγχου αναπαραγωγής είναι σε εστίαση"

msgctxt "#32148"
msgid "Keep the trickplay preview visible while the video OSD play/pause button row has focus (not only when the seek bar is focused)."
msgstr "Διατηρήστε ορατή την προεπισκόπηση trickplay ενώ η σειρά κουμπιών αναπαραγωγής/παύσης OSD βίντεο έχει εστίαση (όχι μόνο όταν η γραμμή αναζήτησης έχει εστίαση)."

msgctxt "#32149"
msgid "Preview cropping needs Pillow (Python imaging library). Download and install a pinned wheel now?\n\nInstall location: %s"
msgstr "Η περικοπή προεπισκόπησης χρειάζεται Pillow (βιβλιοθήκη εικόνας Python). Λήψη και εγκατάσταση ενός καρφιτσωμένου wheel τώρα;\n\nΘέση εγκατάστασης: %s"

msgctxt "#32150"
msgid "Installing Pillow…"
msgstr "Εγκατάσταση Pillow…"

msgctxt "#32151"
msgid "Automatic Pillow install is not available on this Kodi platform/Python version.\n\nInstall Pillow manually into the add-on site-packages folder or use a Kodi build that includes Pillow."
msgstr "Η αυτόματη εγκατάσταση Pillow δεν είναι διαθέσιμη σε αυτή την πλατφόρμα Kodi/έκδοση Python.\n\nΕγκαταστήστε το Pillow χειροκίνητα στον φάκελο site-packages του πρόσθετου ή χρησιμοποιήστε μια έκδοση Kodi που περιλαμβάνει Pillow."

msgctxt "#32152"
msgid "Pillow install failed:\n%s\n\nYou can install manually into the add-on site-packages folder shown in the prompt."
msgstr "Η εγκατάσταση Pillow απέτυχε:\n%s\n\nΜπορείτε να εγκαταστήσετε χειροκίνητα στον φάκελο site-packages του πρόσθετου που εμφανίζεται στην προτροπή."

msgctxt "#32153"
msgid "Pillow installed (%s)."
msgstr "Το Pillow εγκαταστάθηκε (%s)."

msgctxt "#32154"
msgid "Install skin snippet (current skin)"
msgstr "Εγκατάσταση απόσπασμα θέματος (τρέχον θέμα)"

msgctxt "#32155"
msgid "Back up and install the trickplay preview block into the active skin (DialogSeekBar.xml, or VideoFullScreen.xml for Bello). Merge overlay or replace full file for supported skins. Reloads the skin when done. Stale overlays are updated automatically."
msgstr "Δημιουργία αντιγράφου ασφαλείας και εγκατάσταση του μπλοκ προεπισκόπησης trickplay στο ενεργό θέμα (DialogSeekBar.xml, ή VideoFullScreen.xml για Bello). Συγχώνευση επικάλυψης ή αντικατάσταση πλήρους αρχείου για υποστηριζόμενα θέματα. Επαναφόρτωση του θέματος όταν τελειώσει. Οι παρωχημένες επικαλύψεις ενημερώνονται αυτόματα."

msgctxt "#32156"
msgid "Install skin snippet (all skins)"
msgstr "Εγκατάσταση απόσπασμα θέματος (όλα τα θέματα)"

msgctxt "#32157"
msgid "Back up and install the trickplay preview block for every installed skin that has a matching target XML (DialogSeekBar.xml, or VideoFullScreen.xml for Bello). Skins without a target are reported as failed."
msgstr "Δημιουργία αντιγράφου ασφαλείας και εγκατάσταση του μπλοκ προεπισκόπησης trickplay για κάθε εγκατεστημένο θέμα που έχει αντίστοιχο XML στόχο (DialogSeekBar.xml, ή VideoFullScreen.xml για Bello). Τα θέματα χωρίς στόχο αναφέρονται ως αποτυχημένα."

msgctxt "#32158"
msgid "Install skin snippet"
msgstr "Εγκατάσταση απόσπασμα θέματος"

msgctxt "#32159"
msgid "Skins identified:\n%s\n\nInstall trickplay preview controls now?"
msgstr "Θέματα που εντοπίστηκαν:\n%s\n\nΕγκατάσταση στοιχείων ελέγχου προεπισκόπησης trickplay τώρα;"

msgctxt "#32161"
msgid "DialogSeekBar.xml not found"
msgstr "Το DialogSeekBar.xml δεν βρέθηκε"

msgctxt "#32162"
msgid "Installed: %d path(s) ok, %d failed (%d skin(s) processed)."
msgstr "Εγκαταστάθηκε: %d διαδρομή/ές ok, %d απέτυχαν (%d θέμα/τα επεξεργάστηκαν)."

msgctxt "#32163"
msgid "No skin could be identified. Set a skin under Settings → Interface → Skin or install a skin add-on first."
msgstr "Δεν ήταν δυνατός ο εντοπισμός θέματος. Ορίστε ένα θέμα στις Ρυθμίσεις → Διεπαφή → Θέμα ή εγκαταστήστε πρώτα ένα πρόσθετο θέματος."

msgctxt "#32164"
msgid "Install"
msgstr "Εγκατάσταση"

msgctxt "#32165"
msgid "DialogSeekBar.xml is not writable (check skin folder permissions)"
msgstr "Το DialogSeekBar.xml δεν είναι εγγράψιμο (ελέγξτε τα δικαιώματα φακέλου θέματος)"

msgctxt "#32166"
msgid "Could not resolve skin add-on folder"
msgstr "Δεν ήταν δυνατή η επίλυση του φακέλου πρόσθετου θέματος"

msgctxt "#32167"
msgid "Snippet file missing from add-on package"
msgstr "Λείπει το αρχείο απόσπασμα από το πακέτο πρόσθετου"

msgctxt "#32168"
msgid "Backup failed: %s"
msgstr "Το αντίγραφο ασφαλείας απέτυχε: %s"

msgctxt "#32170"
msgid "OK (existing .bak kept)"
msgstr "OK (υπάρχον .bak διατηρήθηκε)"

msgctxt "#32171"
msgid "OK"
msgstr "OK"

msgctxt "#32172"
msgid "Install Pillow (preview)"
msgstr "Εγκατάσταση Pillow (προεπισκόπηση)"

msgctxt "#32173"
msgid "Download Pillow into add-on site-packages for preview thumbnail cropping."
msgstr "Λήψη Pillow στα site-packages του πρόσθετου για περικοπή μικρογραφιών προεπισκόπησης."

msgctxt "#32174"
msgid "Install generator tools (ffmpeg)"
msgstr "Εγκατάσταση εργαλείων γεννήτριας (ffmpeg)"

msgctxt "#32175"
msgid "Download ffmpeg/ffprobe and optional HDR extras (zscale/libplacebo, Vulkan loader on Windows, dovi_tool) for trickplay generation."
msgstr "Λήψη ffmpeg/ffprobe και προαιρετικών πρόσθετων HDR (zscale/libplacebo, φορτωτής Vulkan στα Windows, dovi_tool) για δημιουργία trickplay."

msgctxt "#32176"
msgid "Install preview tools (all)"
msgstr "Εγκατάσταση εργαλείων προεπισκόπησης (όλα)"

msgctxt "#32177"
msgid "Install Pillow for preview cropping, and when the generator is enabled or HDR tone mapping is on, also offers ffmpeg/ffprobe and optional HDR extras."
msgstr "Εγκατάσταση Pillow για περικοπή προεπισκόπησης και, όταν η γεννήτρια είναι ενεργοποιημένη ή η αντιστοίχιση τόνων HDR είναι ενεργή, προσφέρει επίσης ffmpeg/ffprobe και προαιρετικά πρόσθετα HDR."

msgctxt "#32178"
msgid "Restore skin snippet (current skin)"
msgstr "Επαναφορά απόσπασμα θέματος (τρέχον θέμα)"

msgctxt "#32179"
msgid "Restore the active skin's DialogSeekBar.xml from DialogSeekBar.xml.bak when a backup exists. Reloads the skin when done."
msgstr "Επαναφορά του DialogSeekBar.xml του ενεργού θέματος από το DialogSeekBar.xml.bak όταν υπάρχει αντίγραφο ασφαλείας. Επαναφόρτωση του θέματος όταν τελειώσει."

msgctxt "#32180"
