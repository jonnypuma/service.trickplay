# Kodi language file
# Addon: service.trickplay
msgid ""
msgstr ""
"Language: nb\n"
"Content-Type: text/plain; charset=UTF-8\n"

msgctxt "#32000"
msgid "General"
msgstr "Generelt"

msgctxt "#32001"
msgid "Trickplay"
msgstr "Trickplay"

msgctxt "#32002"
msgid "Preferred tile width (px)"
msgstr "Foretrukket flisbredde (px)"

msgctxt "#32003"
msgid "Resolution subfolder to prefer inside the .trickplay directory (e.g. 320 for '320 - 10x10 - 10000'). Falls back to the first resolution found."
msgstr "Oppløsningsundermappe som skal foretrekkes i .trickplay-mappen (f.eks. 320 for '320 - 10x10 - 10000'). Faller tilbake til første oppløsning som finnes."

msgctxt "#32004"
msgid "Thumbnail interval (ms)"
msgstr "Miniatyrbildeintervall (ms)"

msgctxt "#32005"
msgid "Preferred interval when selecting a sidecar folder and fallback when the folder name has no interval suffix (legacy '320 - 10x10' uses 10000 ms)."
msgstr "Foretrukket intervall ved valg av sidecar-mappe og fallback når mappenavnet mangler intervallsuffiks (eldre '320 - 10x10' bruker 10000 ms)."

msgctxt "#32006"
msgid "Seek poll interval (ms)"
msgstr "Søkeavsporingsintervall (ms)"

msgctxt "#32007"
msgid "How often to refresh the preview while the seek bar is active. Lower values feel smoother but use more CPU."
msgstr "Hvor ofte forhåndsvisningen skal oppdateres mens søkelinjen er aktiv. Lavere verdier kjennes jevnere, men bruker mer CPU."

msgctxt "#32008"
msgid "Enable debug logging"
msgstr "Aktiver feilsøkingslogging"

msgctxt "#32009"
msgid "Write detailed trickplay resolution messages to the Kodi log."
msgstr "Skriv detaljerte trickplay-oppløsningsmeldinger til Kodi-loggen."

msgctxt "#32010"
msgid "Automatic tile calculation (legacy)"
msgstr "Automatisk flisberegning (eldre)"

msgctxt "#32011"
msgid "Deprecated; use Preview tile grid layout instead."
msgstr "Avskrevet; bruk Forhåndsvisningsflisrutenett i stedet."

msgctxt "#32012"
msgid "Number of tiles"
msgstr "Antall fliser"

msgctxt "#32013"
msgid "Manual grid layout per sprite JPG, e.g. 10x10 or 20x20. Each cell size is still calculated from the JPG width and height divided by these counts."
msgstr "Manuelt rutenett per sprite-JPG, f.eks. 10x10 eller 20x20. Hver cellestørrelse beregnes fortsatt fra JPG-bredde og -høyde delt på disse verdiene."

msgctxt "#32014"
msgid "Skin profile"
msgstr "Skin-profil"

msgctxt "#32015"
msgid "Seek bar geometry and focus IDs for preview placement. Auto detects your active Kodi skin; override if detection fails."
msgstr "Søkelinjens geometri og fokus-ID-er for forhåndsvisningsplassering. Oppdager automatisk aktivt Kodi-skin; overstyr hvis deteksjon feiler."

msgctxt "#32016"
msgid "Auto (detect active skin)"
msgstr "Auto (oppdag aktivt skin)"

msgctxt "#32017"
msgid "Estuary Mod v2"
msgstr "Estuary Mod v2"

msgctxt "#32018"
msgid "Arctic Fuse 3"
msgstr "Arctic Fuse 3"

msgctxt "#32019"
msgid "Preview hold time (seconds)"
msgstr "Forhåndsvisningens holdetid (sekunder)"

msgctxt "#32020"
msgid "How long to keep the preview visible after seeking stops. 0 = until the OSD closes; the thumbnail follows playback while playing."
msgstr "Hvor lenge forhåndsvisningen skal være synlig etter at søking stopper. 0 = til OSD lukkes; miniatyrbildet følger avspillingen under avspilling."

msgctxt "#32021"
msgid "Show timestamp"
msgstr "Vis tidsstempel"

msgctxt "#32022"
msgid "Show the seek position timestamp below the preview thumbnail."
msgstr "Vis søkeposisjonens tidsstempel under forhåndsvisningsminiatyrbildet."

msgctxt "#32023"
msgid "Enable prefetch"
msgstr "Aktiver forhåndshenting"

msgctxt "#32024"
msgid "Pre-crop neighbouring trickplay cells in the background so scrubbing feels faster."
msgstr "Beskjær nærliggende trickplay-celler på forhånd i bakgrunnen slik at skrubbing kjennes raskere."

msgctxt "#32200"
msgid "Prefetch during playback"
msgstr "Forhåndshent under avspilling"

msgctxt "#32201"
msgid "While a video is playing, keep the prefetch radius (thumb indices) warm on both sides of the current playhead — not only when the seek bar opens."
msgstr "Mens en video spilles, hold forhåndshentingsradiusen (miniatyrindekser) varm på begge sider av avspillingshodet — ikke bare når søkelinjen åpnes."

msgctxt "#32202"
msgid "Arctic Fuse 2"
msgstr "Arctic Fuse 2"

msgctxt "#32203"
msgid "Arctic Horizon 2"
msgstr "Arctic Horizon 2"

msgctxt "#32204"
msgid "Arctic Zephyr 2 Resurrection"
msgstr "Arctic Zephyr 2 Resurrection"

msgctxt "#32205"
msgid "Bello"
msgstr "Bello"

msgctxt "#32206"
msgid "Arctic Horizon 2.1 Arizen"
msgstr "Arctic Horizon 2.1 Arizen"

msgctxt "#32207"
msgid "Bingie"
msgstr "Bingie"

msgctxt "#32208"
msgid "Arctic Zephyr Rounded"
msgstr "Arctic Zephyr Rounded"

msgctxt "#32209"
msgid "DialogSeekBar.xml has no seek-bar content (no controls or includes); skipped"
msgstr "DialogSeekBar.xml har ikke søkelinjeinnhold (ingen kontroller eller inkluderinger); hoppet over"

msgctxt "#32210"
msgid "Skin snippet target XML not found"
msgstr "Skin-snippet mål-XML ikke funnet"

msgctxt "#32025"
msgid "Prefetch on playback start"
msgstr "Forhåndshent ved avspillingsstart"

msgctxt "#32026"
msgid "Warm the cache around the current playhead when a video loads."
msgstr "Varm opp bufferen rundt avspillingshodet når en video lastes."

msgctxt "#32027"
msgid "Prefetch whole sprite tile"
msgstr "Forhåndshent hele sprite-flis"

msgctxt "#32028"
msgid "Also queue uncached cells from the current sprite JPG (up to 20 per preview update)."
msgstr "Legg også til ikke-bufrede celler fra gjeldende sprite-JPG (opptil 20 per forhåndsvisningsoppdatering)."

msgctxt "#32029"
msgid "Prefetch idle sprite tile"
msgstr "Forhåndshent inaktiv sprite-flis"

msgctxt "#32030"
msgid "While the seek OSD is open and idle, pre-crop remaining cells in the current sprite tile."
msgstr "Mens søke-OSD er åpen og inaktiv, beskjær gjenværende celler i gjeldende sprite-flis på forhånd."

msgctxt "#32031"
msgid "Prefetch radius (indices)"
msgstr "Forhåndshentingsradius (indekser)"

msgctxt "#32032"
msgid "How many trickplay thumb indices to pre-crop ahead and behind the playhead (symmetric). With a 10 s interval, 5 means about ±50 s. Higher uses more CPU and disk."
msgstr "Hvor mange trickplay-miniatyrindekser som skal beskjæres på forhånd foran og bak avspillingshodet (symmetrisk). Med et 10 s intervall betyr 5 ca. ±50 s. Høyere bruker mer CPU og disk."

msgctxt "#32033"
msgid "Prefetch queue size"
msgstr "Forhåndshentingskøstørrelse"

msgctxt "#32034"
msgid "Maximum pending background crops. Neighbour previews can bump lower-priority jobs when full."
msgstr "Maksimalt antall ventende bakgrunnsbeskjæringer. Nabo-forhåndsvisninger kan skyve lavere prioriterte jobber når køen er full."

msgctxt "#32035"
msgid "Crop cache limit (MB)"
msgstr "Beskjæringsgrense for buffer (MB)"

msgctxt "#32036"
msgid "Maximum disk space for cropped preview JPEGs. Oldest files are removed first. 0 = unlimited."
msgstr "Maksimal diskplass for beskårne forhåndsvisnings-JPEG-er. Eldste filer fjernes først. 0 = ubegrenset."

msgctxt "#32037"
msgid "Prefetch"
msgstr "Forhåndshenting"

msgctxt "#32038"
msgid "Preview opacity (%)"
msgstr "Forhåndsvisningens gjennomsiktighet (%)"

msgctxt "#32039"
msgid "Overall preview transparency (0 = invisible, 100 = fully opaque). Default 100."
msgstr "Generell forhåndsvisningens gjennomsiktighet (0 = usynlig, 100 = helt ugjennomsiktig). Standard 100."

msgctxt "#32040"
msgid "Trickplay generator"
msgstr "Trickplay-generator"

msgctxt "#32041"
msgid "Custom…"
msgstr "Egendefinert…"

msgctxt "#32042"
msgid "Preview tile grid layout"
msgstr "Forhåndsvisningsflisrutenett"

msgctxt "#32043"
msgid "How to divide each sprite JPG when cropping preview thumbnails. Use From folder name for Jellyfin or generator sidecars; pick 20×20 (etc.) if your tiles use a different grid than the folder name."
msgstr "Hvordan hver sprite-JPG skal deles når forhåndsvisningsminiatyrer beskjæres. Bruk Fra mappenavn for Jellyfin eller generator-sidecars; velg 20×20 (osv.) hvis flisene dine bruker et annet rutenett enn mappenavnet."

msgctxt "#32044"
msgid "10×10"
msgstr "10×10"

msgctxt "#32045"
msgid "20×20"
msgstr "20×20"

msgctxt "#32046"
msgid "5×5"
msgstr "5×5"

msgctxt "#32047"
msgid "15×15"
msgstr "15×15"

msgctxt "#32050"
msgid "Enable trickplay generator"
msgstr "Aktiver trickplay-generator"

msgctxt "#32051"
msgid "Generate Jellyfin-compatible .trickplay sprite sidecars with ffmpeg. When disabled, all generator options are hidden."
msgstr "Generer Jellyfin-kompatible .trickplay sprite-sidecars med ffmpeg. Når deaktivert, skjules alle generatoralternativer."

msgctxt "#32052"
msgid "Generate while idle"
msgstr "Generer ved inaktivitet"

msgctxt "#32053"
msgid "When Kodi is not playing video, generate trickplay for one library file at a time from the library folder below."
msgstr "Når Kodi ikke spiller video, generer trickplay for én bibliotekfil om gangen fra biblioteksmappen nedenfor."

msgctxt "#32054"
msgid "Overwrite existing sidecars"
msgstr "Overskriv eksisterende sidecars"

msgctxt "#32055"
msgid "Regenerate and replace trickplay when a matching .trickplay folder already exists for the preferred width and grid. Off by default."
msgstr "Regenerer og erstatt trickplay når en matchende .trickplay-mappe allerede finnes for foretrukket bredde og rutenett. Av som standard."

msgctxt "#32056"
msgid "Library folder"
msgstr "Biblioteksmappe"

msgctxt "#32057"
msgid "Root folder scanned for batch generation and idle generation. Uses the preferred tile width, interval, and generator grid above. Press OK when leaving Configure to save changes. Start batch generation from the add-on Information page (Run), not from inside Configure."
msgstr "Rotmappe skannet for batch-generering og inaktiv generering. Bruker foretrukket flisbredde, intervall og generatorrutenett ovenfor. Trykk OK når du forlater Konfigurer for å lagre endringer. Start batch-generering fra tilleggsinformasjonssiden (Kjør), ikke fra Konfigurer."

msgctxt "#32058"
msgid "Grid used when writing new .trickplay sidecars (folder name e.g. '320 - 10x10 - 10000')."
msgstr "Rutenett brukt ved skriving av nye .trickplay-sidecars (mappenavn f.eks. '320 - 10x10 - 10000')."

msgctxt "#32059"
msgid "Run library batch generation…"
msgstr "Kjør bibliotekbatch-generering…"

msgctxt "#32060"
msgid "Scan the library folder and generate trickplay for all videos missing sidecars. Shows a progress dialog. Run from the add-on Information page after saving Configure with OK."
msgstr "Skann biblioteksmappen og generer trickplay for alle videoer som mangler sidecars. Viser en fremdriftsdialog. Kjør fra tilleggsinformasjonssiden etter å ha lagret Konfigurer med OK."

msgctxt "#32061"
msgid "Select library folder"
msgstr "Velg biblioteksmappe"

msgctxt "#32062"
msgid "Enable the trickplay generator in settings first."
msgstr "Aktiver trickplay-generatoren i innstillingene først."

msgctxt "#32063"
msgid "Batch trickplay generation"
msgstr "Batch trickplay-generering"

msgctxt "#32064"
msgid "Generate trickplay for all videos under:\n%s"
msgstr "Generer trickplay for alle videoer under:\n%s"

msgctxt "#32065"
msgid "Use this folder"
msgstr "Bruk denne mappen"

msgctxt "#32066"
msgid "Choose another…"
msgstr "Velg en annen…"

msgctxt "#32067"
msgid "No videos need trickplay generation in that folder."
msgstr "Ingen videoer trenger trickplay-generering i den mappen."

msgctxt "#32068"
msgid "Generate trickplay for %d video(s)? This may take a long time."
msgstr "Generer trickplay for %d video(er)? Dette kan ta lang tid."

msgctxt "#32083"
msgid "Generate trickplay for %d of %d video(s)? %d already have matching sidecars and will be skipped."
msgstr "Generer trickplay for %d av %d video(er)? %d har allerede matchende sidecars og vil bli hoppet over."

msgctxt "#32069"
msgid "Generating trickplay…"
msgstr "Genererer trickplay…"

msgctxt "#32070"
msgid "File %d of %d"
msgstr "Fil %d av %d"

msgctxt "#32071"
msgid "Done. Success: %d  Failed: %d"
msgstr "Ferdig. Vellykket: %d  Mislyktes: %d"

msgctxt "#32072"
msgid "From folder name"
msgstr "Fra mappenavn"

msgctxt "#32073"
msgid "Generator tile grid layout"
msgstr "Generatorflisrutenett"

msgctxt "#32074"
msgid "Generator thumbnail interval (ms)"
msgstr "Generatorminiatyrbildeintervall (ms)"

msgctxt "#32075"
msgid "Time between generated preview frames. Written into the sidecar folder name (e.g. '320 - 10x10 - 1000'). Playback preview uses the interval from the folder when present; legacy folders without an interval use 10000 ms."
msgstr "Tid mellom genererte forhåndsvisningsrammer. Skrevet inn i sidecar-mappenavnet (f.eks. '320 - 10x10 - 1000'). Avspillingsforhåndsvisning bruker intervallet fra mappen når tilstede; eldre mapper uten intervall bruker 10000 ms."

msgctxt "#32076"
msgid "Frame extraction mode"
msgstr "Rammeekstraksjons-modus"

msgctxt "#32077"
msgid "Accurate: one ffmpeg call per thumbnail, seek after input (slow, frame-accurate). Fast: seek before input per thumbnail for wide intervals, or one fps decode pass per tile for intervals of 5s or less. Fast (batch seeks): several seek-before-input captures per ffmpeg process (small chunks) with per-frame Fast fallback; optional PyAV on local SDR. Biggest gains on local SDR files."
msgstr "Nøyaktig: én ffmpeg-kall per miniatyrbilde, søk etter inndata (sakte, rammenøyaktig). Rask: søk før inndata per miniatyrbilde for store intervaller, eller én fps-dekodingsgjennomgang per flis for intervaller på 5s eller mindre. Eksperimentell: én filøpning med søk mellom opptak (PyAV når tilgjengelig, ellers én ffmpeg-prosess med mange søk per flis)."

msgctxt "#32080"
msgid "Accurate (slow)"
msgstr "Nøyaktig (sakte)"

msgctxt "#32081"
msgid "Fast"
msgstr "Rask"

msgctxt "#32082"
msgid "Fast (batch seeks)"
msgstr "Fast (batch seeks)"

msgctxt "#32078"
msgid "Stop batch on first failure"
msgstr "Stopp batch ved første feil"

msgctxt "#32079"
msgid "When running Generate trickplay for library, stop the batch after the first file that fails instead of continuing with the remaining videos."
msgstr "Når du kjører Generer trickplay for bibliotek, stopp batchen etter den første filen som mislykkes i stedet for å fortsette med gjenværende videoer."

msgctxt "#32084"
msgid "Generate on library update"
msgstr "Generer ved bibliotekoppdatering"

msgctxt "#32085"
msgid "After a video library scan finishes, generate trickplay for videos added during that scan. Listens for VideoLibrary.OnAdd and OnUpdate (added) notifications."
msgstr "Etter at en videobibliotekskanning er ferdig, generer trickplay for videoer lagt til under den skanningen. Lytter etter VideoLibrary.OnAdd og OnUpdate (lagt til) varsler."

msgctxt "#32086"
msgid "Library update: only when not playing"
msgstr "Bibliotekoppdatering: bare når ikke spiller"

msgctxt "#32087"
msgid "Wait until Kodi is not playing video before starting trickplay generation for newly added library items."
msgstr "Vent til Kodi ikke spiller video før trickplay-generering startes for nylig tillagte bibliotekobjekter."

msgctxt "#32088"
msgid "That folder is not a valid library path. Choose a folder that contains your video files (for example an NFS share or /storage/remote-shares/…)."
msgstr "Den mappen er ikke en gyldig bibliotekbane. Velg en mappe som inneholder videofilene dine (for eksempel en NFS-deling eller /storage/remote-shares/…)."

msgctxt "#32089"
msgid "Interval selection"
msgstr "Intervallvalg"

msgctxt "#32090"
msgid "When multiple sidecar folders exist for the same tile width (e.g. 320 - 10x10 - 5000 and 320 - 10x10 - 10000), choose which interval to use during playback. Preferred uses the Preview thumbnail interval setting; Shortest uses the smallest interval available."
msgstr "Når flere sidecar-mapper finnes for samme flisbredde (f.eks. 320 - 10x10 - 5000 og 320 - 10x10 - 10000), velg hvilket intervall som skal brukes under avspilling. Foretrukket bruker innstillingen Forhåndsvisningsminiatyrbildeintervall; Kortest bruker det minste tilgjengelige intervallet."

msgctxt "#32091"
msgid "Preferred interval"
msgstr "Foretrukket intervall"

msgctxt "#32092"
msgid "Shortest interval"
msgstr "Kortest intervall"

msgctxt "#32093"
msgid "HDR tone mapping for previews"
msgstr "HDR tone mapping for forhåndsvisninger"

msgctxt "#32094"
msgid "Tone-map HDR and Dolby Vision sources to SDR when generating trickplay JPEGs so colours match normal playback (similar to Jellyfin). Only applies to HDR/DV files; SDR generation is unchanged. Significantly slower on 4K HEVC — often several times longer per file — and requires ffmpeg tonemap support. Leave off if Jellyfin already generates sidecars or generation time matters."
msgstr "Tone-map HDR og Dolby Vision-kilder til SDR ved generering av trickplay-JPEG-er slik at farger matcher normal avspilling (lignende Jellyfin). Gjelder bare for HDR/DV-filer; SDR-generering er uendret. Betydelig tregere på 4K HEVC — ofte flere ganger lengre per fil — og krever ffmpeg tonemap-støtte. La stå av hvis Jellyfin allerede genererer sidecars eller genereringstid er viktig."

msgctxt "#32095"
msgid "HDR dovi_tool fallback"
msgstr "HDR dovi_tool fallback"

msgctxt "#32096"
msgid "When HDR tone mapping is on, run dovi_tool on the first seconds of HEVC if ffprobe finds no HDR signals. Slower; place dovi_tool in generator ffmpeg bin/ (same folder as HDR ffmpeg) or on PATH. Use for stubborn Dolby Vision remuxes. Skipped for VFS stream paths. With fallback on, Run can offer to download dovi_tool there."
msgstr "Når HDR tone mapping er på, kjør dovi_tool på de første sekundene av HEVC hvis ffprobe ikke finner HDR-signaler. Tregere; plasser dovi_tool i generator ffmpeg bin/ (samme mappe som HDR ffmpeg) eller på PATH. Bruk for stædig Dolby Vision remuxer. Hoppet over for VFS-strømbaner. Med fallback på, kan Kjør tilby å laste ned dovi_tool der."

msgctxt "#32097"
msgid "Generator ffmpeg path"
msgstr "Generator ffmpeg-bane"

msgctxt "#32098"
msgid "Optional folder or ffmpeg binary for trickplay generation (needs zscale or libplacebo for HDR tone mapping). Preview cropping uses Pillow separately. Leave empty to use /storage/.kodi/system/ffmpeg/ on Linux Kodi, or addon_data/service.trickplay/system/ffmpeg/ on Windows, when present; otherwise PATH. Use Install preview tools when the generator or HDR tone mapping is enabled, or batch Run when generating."
msgstr "Valgfri mappe eller ffmpeg-binær for trickplay-generering (trenger zscale eller libplacebo for HDR tone mapping). Forhåndsvisningsbeskjæring bruker Pillow separat. La stå tom for å bruke /storage/.kodi/system/ffmpeg/ på Linux Kodi, eller addon_data/service.trickplay/system/ffmpeg/ på Windows, når tilstede; ellers PATH. Bruk Installer forhåndsvisningsverktøy når generatoren eller HDR tone mapping er aktivert, eller batch Kjør ved generering."

msgctxt "#32099"
msgid "HDR tone mapping needs a capable ffmpeg build. Download and install now?\n\nLinux: BtbN gpl-8.1 (zscale). Windows: Gyan full build (zscale + libplacebo for Dolby Vision via Vulkan).\n\nOn devices without Vulkan (e.g. CoreELEC), Profile 5 Dolby Vision uses dovi_tool instead of libplacebo.\n\nInstall location: %s"
msgstr "HDR tone mapping trenger en kapabel ffmpeg-build. Laste ned og installer nå?\n\nLinux: BtbN gpl-8.1 (zscale). Windows: Gyan full build (zscale + libplacebo for Dolby Vision via Vulkan).\n\nPå enheter uten Vulkan (f.eks. CoreELEC), bruker Profile 5 Dolby Vision dovi_tool i stedet for libplacebo.\n\nInstallasjonssted: %s"

msgctxt "#32100"
msgid "Continue without"
msgstr "Fortsett uten"

msgctxt "#32101"
msgid "Installing HDR ffmpeg…"
msgstr "Installerer HDR ffmpeg…"

msgctxt "#32102"
msgid "Automatic HDR ffmpeg install is not supported on this platform. Install a BtbN build manually (see README)."
msgstr "Automatisk HDR ffmpeg-installasjon støttes ikke på denne plattformen. Installer en BtbN-build manuelt (se README)."

msgctxt "#32103"
msgid "HDR ffmpeg install failed:\n%s\n\nYou can install manually or continue with the current ffmpeg (HDR previews may look washed out)."
msgstr "HDR ffmpeg-installasjon mislyktes:\n%s\n\nDu kan installere manuelt eller fortsette med gjeldende ffmpeg (HDR-forhåndsvisninger kan se utvaskede ut)."

msgctxt "#32104"
msgid "HDR ffmpeg installed (%s)."
msgstr "HDR ffmpeg installert (%s)."

msgctxt "#32105"
msgid "Download"
msgstr "Last ned"

msgctxt "#32106"
msgid "dovi_tool is required on this device for Dolby Vision trickplay (no Vulkan / libvulkan) or when HDR dovi_tool fallback is enabled. Download and install dovi_tool beside generator ffmpeg now?\n\nInstall location: %s"
msgstr "dovi_tool er påkrevd på denne enheten for Dolby Vision trickplay (ingen Vulkan / libvulkan) eller når HDR dovi_tool fallback er aktivert. Laste ned og installer dovi_tool ved siden av generator ffmpeg nå?\n\nInstallasjonssted: %s"

msgctxt "#32107"
msgid "Installing dovi_tool…"
msgstr "Installerer dovi_tool…"

msgctxt "#32108"
msgid "Automatic dovi_tool install is not supported on this platform. Download from quietvoid/dovi_tool releases and place dovi_tool in generator ffmpeg bin/ (see README)."
msgstr "Automatisk dovi_tool-installasjon støttes ikke på denne plattformen. Last ned fra quietvoid/dovi_tool releases og plasser dovi_tool i generator ffmpeg bin/ (se README)."

msgctxt "#32109"
msgid "dovi_tool install failed:\n%s\n\nYou can install manually in generator ffmpeg bin/ or continue without Dolby Vision fallback."
msgstr "dovi_tool-installasjon mislyktes:\n%s\n\nDu kan installere manuelt i generator ffmpeg bin/ eller fortsette uten Dolby Vision fallback."

msgctxt "#32110"
msgid "dovi_tool installed (%s)."
msgstr "dovi_tool installert (%s)."

msgctxt "#32111"
msgid "Run batch in background"
msgstr "Kjør batch i bakgrunnen"

msgctxt "#32112"
msgid "When enabled, batch Run shows a start notification and runs without the progress dialog. Progress is written to the Kodi log. You cannot cancel from the UI (stop Kodi or wait for completion). A notification is shown when the batch finishes."
msgstr "Når aktivert, viser batch Kjør en startvarsling og kjører uten fremdriftsdialogen. Fremdrift skrives til Kodi-loggen. Du kan ikke avbryte fra UI (stopp Kodi eller vent på fullføring). En varsling vises når batchen er ferdig."

msgctxt "#32113"
msgid "Generating trickplay for %d file(s) — see log for progress"
msgstr "Genererer trickplay for %d fil(er) — se loggen for fremdrift"

msgctxt "#32114"
msgid "Skip Dolby Vision Profile 5"
msgstr "Hopp over Dolby Vision Profile 5"

msgctxt "#32115"
msgid "When enabled, batch generation skips web-style Dolby Vision Profile 5 files (e.g. .DV. releases). Profile 5 needs a full dovi_tool convert before tonemapping — often hours plus ~1× video size temp space on devices like CoreELEC. Use a desktop with Vulkan or leave this off to process them."
msgstr "Når aktivert, hopper batch-generering over web-stil Dolby Vision Profile 5-filer (f.eks. .DV.-utgaver). Profile 5 trenger en full dovi_tool-konvertering før tonemapping — ofte timer pluss ~1× videostørrelse temp-plass på enheter som CoreELEC. Bruk en stasjonær med Vulkan eller la dette stå av for å behandle dem."

msgctxt "#32116"
msgid "Generate trickplay for %d of %d video(s)? %d skipped (matching sidecars), %d skipped (Dolby Vision Profile 5)."
msgstr "Generer trickplay for %d av %d video(er)? %d hoppet over (matchende sidecars), %d hoppet over (Dolby Vision Profile 5)."

msgctxt "#32117"
msgid "Generate trickplay for %d of %d video(s)? %d skipped (Dolby Vision Profile 5)."
msgstr "Generer trickplay for %d av %d video(er)? %d hoppet over (Dolby Vision Profile 5)."

msgctxt "#32118"
msgid "Vulkan (vulkan-1.dll) is missing on this PC. Dolby Vision via libplacebo needs it. Download and install the Vulkan loader next to ffmpeg?\n\nInstall location: %s"
msgstr "Vulkan (vulkan-1.dll) mangler på denne PC-en. Dolby Vision via libplacebo trenger den. Laste ned og installer Vulkan-lasteren ved siden av ffmpeg?\n\nInstallasjonssted: %s"

msgctxt "#32119"
msgid "Vulkan loader installed (%s)."
msgstr "Vulkan-laster installert (%s)."

msgctxt "#32120"
msgid "Windows hardware decode"
msgstr "Windows maskinvaredekoding"

msgctxt "#32121"
msgid "On Windows only: D3D11VA (GPU) for 10-bit / HDR / Dolby Vision HEVC (~25–30% faster on 4K HDR/DV). Not for general use — 1080p H.264 SDR should use software decode (often faster, especially on deep seeks); long-interval SDR uses fps-batch per tile. Skipped for AVC and SDR 8-bit HEVC. After the first HW failure on a file, software decode is used for the rest of that job. Requires a full Windows ffmpeg build (e.g. Gyan full from Run). No effect on Linux or CoreELEC."
msgstr "Kun på Windows: D3D11VA (GPU) for 10-bit / HDR / Dolby Vision HEVC (~25–30% raskere på 4K HDR/DV). Ikke for generell bruk — 1080p H.264 SDR bør bruke programvaredekoding (ofte raskere, spesielt ved dype søk); lang-intervall SDR bruker fps-batch per flis. Hoppet over for AVC og SDR 8-bit HEVC. Etter første HW-feil på en fil, brukes programvaredekoding for resten av den jobben. Krever en full Windows ffmpeg-build (f.eks. Gyan full fra Kjør). Ingen effekt på Linux eller CoreELEC."

msgctxt "#32122"
msgid "Preview tools"
msgstr "Forhåndsvisningsverktøy"

msgctxt "#32123"
msgid "Install preview tools"
msgstr "Installer forhåndsvisningsverktøy"

msgctxt "#32124"
msgid "Download Pillow for preview cropping (into add-on site-packages). When the generator is enabled or HDR tone mapping is on, also offers ffmpeg/ffprobe and optional HDR extras (zscale/libplacebo, Vulkan loader on Windows, dovi_tool). Batch Run installs generator ffmpeg separately when generating sidecars."
msgstr "Last ned Pillow for forhåndsvisningsbeskjæring (til tilleggs-site-packages). Når generatoren er aktivert eller HDR tone mapping er på, tilbyr også ffmpeg/ffprobe og valgfrie HDR-ekstra (zscale/libplacebo, Vulkan-laster på Windows, dovi_tool). Batch Kjør installerer generator ffmpeg separat ved generering av sidecars."

msgctxt "#32125"
msgid "Trickplay generation needs ffmpeg and ffprobe. Download and install a pinned build now?\n\nLinux: BtbN gpl-8.1. Windows: Gyan full build (zscale + libplacebo for Dolby Vision via Vulkan).\n\nInstall location: %s"
msgstr "Trickplay-generering trenger ffmpeg og ffprobe. Laste ned og installer en pinnet build nå?\n\nLinux: BtbN gpl-8.1. Windows: Gyan full build (zscale + libplacebo for Dolby Vision via Vulkan).\n\nInstallasjonssted: %s"

msgctxt "#32126"
msgid "Installing ffmpeg…"
msgstr "Installerer ffmpeg…"

msgctxt "#32127"
msgid "ffmpeg install failed:\n%s\n\nYou can install manually or set Generator ffmpeg path in add-on settings."
msgstr "ffmpeg-installasjon mislyktes:\n%s\n\nDu kan installere manuelt eller angi Generator ffmpeg-bane i tilleggsinnstillingene."

msgctxt "#32128"
msgid "ffmpeg installed (%s)."
msgstr "ffmpeg installert (%s)."

msgctxt "#32129"
msgid "Preview tools are already installed."
msgstr "Forhåndsvisningsverktøy er allerede installert."

msgctxt "#32130"
msgid "This file has trickplay sidecars but preview thumbnails need Pillow to crop tiles from sprite sheets.\n\nDownload and install Pillow now? You can also use Install preview tools in add-on settings anytime."
msgstr "Denne filen har trickplay-sidecars, men forhåndsvisningsminiatyrer trenger Pillow for å beskjære fliser fra sprite-ark.\n\nLast ned og installer Pillow nå? Du kan også bruke Installer forhåndsvisningsverktøy i tilleggsinnstillingene når som helst."

