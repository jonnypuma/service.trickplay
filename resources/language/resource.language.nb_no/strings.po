msgstr "Tøm forhåndsvisningsbuffer"

msgctxt "#32219"
msgid "Deletes cropped seek thumbs and local sprite tile copies used while scrubbing. Does not remove .trickplay sidecars on your media or generator work folders."
msgstr "Sletter beskårne søkeminiatyrer og lokale sprite-fliskopier brukt under skrubbing. Fjerner ikke .trickplay-sidecars på mediet eller generator-arbeidsmapper."

